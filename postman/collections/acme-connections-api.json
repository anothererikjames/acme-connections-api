{
  "info": {
    "name": "Acme Connections API",
    "description": "Complete test suite for the Acme Connections API v2. Covers connections, partners, webhooks, events, subscriptions, and credentials.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "{{baseUrl}}", "type": "string" },
    { "key": "token", "value": "{{token}}", "type": "string" },
    { "key": "connectionId", "value": "", "type": "string" },
    { "key": "partnerId", "value": "", "type": "string" },
    { "key": "webhookId", "value": "", "type": "string" },
    { "key": "credentialId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response time < 500ms', () => pm.expect(pm.response.responseTime).to.be.below(500));",
                  "pm.test('Status is healthy', () => pm.expect(pm.response.json().status).to.eql('healthy'));",
                  "pm.test('Version is v2.x.x', () => pm.expect(pm.response.json().version).to.match(/^2\\.\\d+\\.\\d+$/));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          }
        }
      ]
    },
    {
      "name": "Partners",
      "item": [
        {
          "name": "POST /partners",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Partner has id', () => pm.expect(pm.response.json()).to.have.property('id'));",
                  "pm.test('Partner name matches', () => pm.expect(pm.response.json().name).to.eql('Test Partner Inc'));",
                  "pm.test('Tier defaults to standard', () => pm.expect(pm.response.json().tier).to.eql('standard'));",
                  "pm.collectionVariables.set('partnerId', pm.response.json().id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"name\": \"Test Partner Inc\", \"contactEmail\": \"partner@testco.com\", \"website\": \"https://testco.com\"}" },
            "url": { "raw": "{{baseUrl}}/partners", "host": ["{{baseUrl}}"], "path": ["partners"] }
          }
        },
        {
          "name": "GET /partners",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has data array', () => pm.expect(pm.response.json().data).to.be.an('array'));",
                  "pm.test('All have valid tier', () => {",
                  "  const validTiers = ['standard','silver','gold','platinum'];",
                  "  pm.response.json().data.forEach(p => pm.expect(validTiers).to.include(p.tier));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/partners", "host": ["{{baseUrl}}"], "path": ["partners"] }
          }
        }
      ]
    },
    {
      "name": "Connections",
      "item": [
        {
          "name": "POST /connections",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Connection has id', () => pm.expect(pm.response.json()).to.have.property('id'));",
                  "pm.test('Type is api_key', () => pm.expect(pm.response.json().type).to.eql('api_key'));",
                  "pm.test('Status is pending or active', () => pm.expect(pm.response.json().status).to.be.oneOf(['pending','active']));",
                  "pm.collectionVariables.set('connectionId', pm.response.json().id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"name\": \"Test Connection\", \"type\": \"api_key\", \"partnerId\": \"{{partnerId}}\"}" },
            "url": { "raw": "{{baseUrl}}/connections", "host": ["{{baseUrl}}"], "path": ["connections"] }
          }
        },
        {
          "name": "GET /connections/:id",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Connection has required fields', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.all.keys('id','name','type','partnerId','status','createdAt','updatedAt');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/connections/{{connectionId}}", "host": ["{{baseUrl}}"], "path": ["connections", "{{connectionId}}"] }
          }
        },
        {
          "name": "POST /connections/:id/test",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has success flag', () => pm.expect(pm.response.json()).to.have.property('success'));",
                  "pm.test('Has latency', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.latencyMs).to.be.a('number').and.to.be.above(0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/connections/{{connectionId}}/test", "host": ["{{baseUrl}}"], "path": ["connections", "{{connectionId}}", "test"] }
          }
        }
      ]
    },
    {
      "name": "Webhooks",
      "item": [
        {
          "name": "POST /webhooks",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Webhook has id', () => pm.expect(pm.response.json()).to.have.property('id'));",
                  "pm.test('Webhook is active', () => pm.expect(pm.response.json().active).to.be.true);",
                  "pm.test('Events array matches', () => {",
                  "  pm.expect(pm.response.json().events).to.include('connection.activated');",
                  "});",
                  "pm.collectionVariables.set('webhookId', pm.response.json().id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": { "mode": "raw", "raw": "{\"connectionId\": \"{{connectionId}}\", \"url\": \"https://webhook.site/test\", \"events\": [\"connection.activated\", \"connection.error\"]}" },
            "url": { "raw": "{{baseUrl}}/webhooks", "host": ["{{baseUrl}}"], "path": ["webhooks"] }
          }
        },
        {
          "name": "GET /webhooks/:id/deliveries",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has data array', () => pm.expect(pm.response.json().data).to.be.an('array'));",
                  "pm.test('No stuck pending deliveries', () => {",
                  "  const stuck = pm.response.json().data.filter(d => {",
                  "    return d.status === 'pending' && (Date.now() - new Date(d.createdAt).getTime()) > 300000;",
                  "  });",
                  "  pm.expect(stuck.length).to.eql(0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/webhooks/{{webhookId}}/deliveries", "host": ["{{baseUrl}}"], "path": ["webhooks", "{{webhookId}}", "deliveries"] }
          }
        }
      ]
    },
    {
      "name": "Events",
      "item": [
        {
          "name": "GET /events",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has data array', () => pm.expect(pm.response.json().data).to.be.an('array'));",
                  "pm.test('Events are sorted newest first', () => {",
                  "  const events = pm.response.json().data;",
                  "  if (events.length > 1) {",
                  "    const first = new Date(events[0].createdAt).getTime();",
                  "    const second = new Date(events[1].createdAt).getTime();",
                  "    pm.expect(first).to.be.at.least(second);",
                  "  }",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/events?limit=50", "host": ["{{baseUrl}}"], "path": ["events"], "query": [{ "key": "limit", "value": "50" }] }
          }
        }
      ]
    }
  ]
}
